# SuffaCampus Backend - temporary testing setup
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Runtime
NODE_ENV=production
PORT=5000
APP_VERSION=1.0.0
COMMIT_SHA=local

# Database (required)
DATABASE_URL=postgresql://postgres:REPLACE_ME@db.example.supabase.co:5432/postgres

# Firebase Admin (required)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# CORS for Netlify webpanel
FRONTEND_URL=https://suffacampus.netlify.app
CORS_ORIGINS=https://suffacampus.netlify.app

# Temporary single-service worker mode
RUN_WORKERS=true
NOTIFICATION_WORKER_MODE=in-process

# Optional: enable Redis-backed queues. App still runs in degraded mode without it.
# REDIS_URL=redis://localhost:6379

# Session JWT
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_ACCESS_TTL_SECONDS=86400
JWT_ISSUER=suffacampus-api
JWT_AUDIENCE=suffacampus-clients
AUTH_ALLOW_FIREBASE_FALLBACK=false

# Payment providers (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# Email (optional)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@suffacampus.app
EMAIL_FROM_NAME=SuffaCampus

# Observability
LOG_LEVEL=info
METRICS_AUTH_TOKEN=replace-with-strong-random-token
SENTRY_DSN=

# Rate limiting and overload controls
RATE_LIMIT_MAX=100
CRITICAL_AUTH_LOOKUP_CONCURRENCY=150
CRITICAL_AUTH_LOGIN_CONCURRENCY=120
CRITICAL_DASHBOARD_CONCURRENCY=220

# External API keys (optional, comma-separated key:name format)
API_KEYS=

# Bootstrap helper script inputs (optional)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_DISPLAY_NAME=


