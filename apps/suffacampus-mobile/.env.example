# ═══════════════════════════════════════════════════════════════════
# SuffaCampus Mobile — Environment Variables
# These variables are loaded via Expo's env system.
# Prefix with EXPO_PUBLIC_ for client-side access.
# ═══════════════════════════════════════════════════════════════════

# ── App Environment ────────────────────────────────────────────────
# Controls environment detection in config/env.ts
# Values: development | staging | production
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=SuffaCampus

# ── Backend API URL (REQUIRED) ─────────────────────────────────────
# Must include the /api/v1 prefix.
# The app will crash at startup if this is missing.
# Dev:  http://localhost:5000/api/v1
# Prod: https://your-backend.azurewebsites.net/api/v1
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# ── Firebase (REQUIRED — 4 keys mandatory) ─────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Script-only test credentials ───────────────────────────────────
# Required by scripts/setupTestUsers.ts and scripts/addUsernames.js
TEST_STUDENT_EMAIL=
TEST_STUDENT_PASSWORD=
TEST_STUDENT_NAME=
TEST_TEACHER_EMAIL=
TEST_TEACHER_PASSWORD=
TEST_TEACHER_NAME=
