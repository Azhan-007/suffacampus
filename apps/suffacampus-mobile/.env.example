# For physical devices, use your PC's LAN IP (e.g., 192.168.1.x)
# For emulators: Android uses 10.0.2.2, iOS uses localhost
EXPO_PUBLIC_APP_NAME=SuffaCampus
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# â”€â”€ Firebase (configured in firebase.ts, not typically overridden) â”€â”€
EXPO_PUBLIC_FIREBASE_API_KEY=
